# ============================================
# 学生教育系统智能体 - 环境配置
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=localhost

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=education_system
DB_CONNECTION_LIMIT=10

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_please_change_in_production
JWT_EXPIRES_IN=7d

# 智谱AI配置
ZHIPU_API_KEY=149da08774b64a54a0ea4b800530fdee.P2SrTmYcbvLDO5bx
ZHIPU_API_URL=https://open.bigmodel.cn/api/anthropic
ZHIPU_MODEL=claude-sonnet-4-6

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS配置
CORS_ORIGIN=*
