# ============================================
# 学生教育系统智能体 - 环境配置
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=localhost

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=education_system
DB_CONNECTION_LIMIT=10

# JWT配置
JWT_SECRET=education_system_jwt_secret_key_2026_hailei_chan
JWT_EXPIRES_IN=7d

# 智谱AI配置
ZHIPU_API_KEY=6b6f0239db8b46c6bd4b7f6d6c9962cf.tOotWQW3BGZJwTuo
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# Embedding服务配置
# 模式说明：
# - api: 使用智谱AI Embedding API（已优化：持久化缓存+请求队列，推荐！）
# - local: 使用本地embedding模型（完全免费，但在Windows安装复杂）
EMBEDDING_MODE=api

# Rerank服务配置
# 模式说明：
# - none: 禁用Rerank（最快，效果一般）
# - local: 本地Rerank（推荐：快、免费、效果较好）
# - hybrid: 混合模式（优先API，失败时降级到本地）
# - api: 仅使用API Rerank（需要充值）
RERANK_MODE=local
RERANK_MODEL=rerank
RERANK_TIMEOUT=30000
RERANK_CACHE_ENABLED=true

# 增强版本地Rerank配置
ENHANCED_LOCAL_RERANK=true
LOCAL_RERANK_KEYWORD_WEIGHT=0.25
LOCAL_RERANK_SEMANTIC_WEIGHT=0.65
LOCAL_RERANK_CONTEXT_WEIGHT=0.10

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS配置
CORS_ORIGIN=*

# Coze平台配置
COZE_API_KEY=coze-api-key-2026-hailei-chan-change-this
# 警告：请将上面的密钥改为一个强密码，并在Coze插件中使用相同的密钥！
