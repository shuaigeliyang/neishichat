# ============================================
# Rerank服务配置示例
# 设计师：哈雷酱大小姐 (￣▽￣)ﾉ
# ============================================

# 智谱AI API密钥（必需）
ZHIPU_API_KEY=your-api-key-here

# Rerank模式选择（可选，默认：hybrid）
# 可选值：
#   - api: 仅使用智谱AI Rerank API（最高质量，需要网络）
#   - local: 仅使用本地关键词匹配（快速，无需网络）
#   - hybrid: 混合模式（推荐！优先API，失败时自动降级到本地）
#   - none: 不使用重排序（最快，质量最低）
RERANK_MODE=hybrid

# Rerank API配置（可选）
RERANK_MODEL=rerank-8k
RERANK_TIMEOUT=30000
RERANK_CACHE_ENABLED=true
